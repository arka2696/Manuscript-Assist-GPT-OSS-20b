Bootstrap: docker
From: nvidia/cuda:12.1.1-devel-ubuntu22.04

%post
    # Prevent interactive prompts
    export DEBIAN_FRONTEND=noninteractive
    
    # 1. System Dependencies
    apt-get update && apt-get install -y \
        build-essential \
        cmake \
        git \
        wget \
        curl \
        python3 \
        python3-pip \
        nano \
        && rm -rf /var/lib/apt/lists/*
        
    # 2. Node.js (For the NumaScribe React Frontend)
    curl -fsSL https://deb.nodesource.com/setup_20.x | bash -
    apt-get install -y nodejs
    
    # 3. Python Dependencies (FastAPI, LangGraph, Open-WebUI)
    pip3 install --no-cache-dir \
        fastapi \
        uvicorn \
        httpx \
        langgraph \
        langchain-core \
        open-webui
        
    # 4. Experimental LLAMA.CPP (TurboQuant Fork)
    cd /opt
    git clone https://github.com/TheTom/llama-cpp-turboquant.git
    cd llama-cpp-turboquant
    git checkout feature/turboquant-kv-cache
    
    # Compile with CUDA 12
    cmake -B build -DGGML_CUDA=ON -DCMAKE_BUILD_TYPE=Release
    cmake --build build -j $(nproc)
    
    # Make accessible globally
    ln -s /opt/llama-cpp-turboquant/build/bin/llama-server /usr/local/bin/llama-server
    ln -s /opt/llama-cpp-turboquant/build/bin/llama-cli /usr/local/bin/llama-cli

%environment
    export DEBIAN_FRONTEND=noninteractive
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8

%runscript
    echo "Welcome to NumaScribe TurboQuant + Open WebUI Container!"
    exec "$@"
